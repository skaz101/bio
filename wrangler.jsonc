{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bio",
  "main": "./worker.js",
  "compatibility_date": "2026-06-19",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "VIEWS"
    }
  ]
}
